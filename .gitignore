<!DOCTYPE html>
<html lang="en">
<head>

    <!-- Basic page setup -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Title that appears in the browser tab -->
    <title>Giancarlo Montanaro | Business Management Portfolio</title>

    <!-- Link to external CSS stylesheet -->
    <link rel="stylesheet" href="styles.css">

    <!-- Google font for professional typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

</head>
<body>

<!-- =========================
     NAVIGATION BAR
     Appears at the top of the website
========================= -->

<nav class="navbar">

    <div class="logo">GM</div>

    <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#goals">Goals</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>

</nav>


<!-- =========================
     HERO SECTION
     First section visitors see
========================= -->

<section class="hero">

    <div class="hero-text">

        <h1>Giancarlo Montanaro</h1>

        <p>Business Management Student</p>

        <p class="hero-description">
            First-year business student passionate about entrepreneurship,
            leadership, and learning how businesses grow in competitive markets.
        </p>

        <a href="#projects" class="button">View My Work</a>

    </div>

</section>


<!-- =========================
     ABOUT SECTION
========================= -->

<section id="about" class="section">

    <h2>About Me</h2>

    <div class="about-container">

        <!-- Profile photo -->
        <img src="images/profile.jpg" alt="Profile Photo" class="profile-photo">

        <div>

            <p>
                I'm a first-year Business Management student interested in
                entrepreneurship, leadership, and business strategy.
                My goal during college is to build a strong foundation in
                business principles while exploring real-world applications.
            </p>

            <p>
                I'm currently developing skills in research, data analysis,
                teamwork, and AI-assisted tools that help businesses
                make smarter decisions.
            </p>

        </div>

    </div>

</section>


<!-- =========================
     PROJECTS SECTION
========================= -->

<section id="projects" class="section">

    <h2>Academic Projects</h2>

    <div class="project-grid">

        <div class="project-card">
            <h3>Business Case Study</h3>
            <p>
                Analyzed a company's marketing strategy and evaluated how
                digital platforms impact customer engagement.
            </p>
        </div>

        <div class="project-card">
            <h3>AI in Business Research</h3>
            <p>
                Researched how artificial intelligence tools can improve
                decision-making and productivity in modern organizations.
            </p>
        </div>

        <div class="project-card">
            <h3>Market Analysis Project</h3>
            <p>
                Conducted research on emerging trends within a chosen
                industry and presented strategic insights.
            </p>
        </div>

    </div>

</section>


<!-- =========================
     SKILLS SECTION
========================= -->

<section id="skills" class="section">

    <h2>Skills</h2>

    <div class="skills-grid">

        <div>
            <h3>Business Skills</h3>
            <ul>
                <li>Market research</li>
                <li>Business analysis</li>
                <li>Presentation skills</li>
            </ul>
        </div>

        <div>
            <h3>Technical Skills</h3>
            <ul>
                <li>Microsoft Excel</li>
                <li>Google Workspace</li>
                <li>AI-assisted research</li>
            </ul>
        </div>

        <div>
            <h3>Soft Skills</h3>
            <ul>
                <li>Communication</li>
                <li>Problem solving</li>
                <li>Team collaboration</li>
            </ul>
        </div>

    </div>

</section>


<!-- =========================
     CAREER GOALS SECTION
========================= -->

<section id="goals" class="section">

    <h2>Career Goals</h2>

    <p class="center-text">
        My long-term goal is to build a career in business management where
        I can help organizations grow and adapt in competitive markets.
        During college I hope to gain experience through internships,
        projects, and collaboration with other students and professionals.
    </p>

</section>


<!-- =========================
     CONTACT SECTION
========================= -->

<section id="contact" class="section">

    <h2>Contact</h2>

    <p class="center-text">
        Feel free to connect with me for collaboration, networking,
        or professional opportunities.
    </p>

    <div class="contact-info">
        <p>Email: yourname@email.com</p>
        <p>LinkedIn: linkedin.com/in/yourname</p>
    </div>

</section>


<!-- =========================
     FOOTER
========================= -->

<footer>

    <p>© 2026 Giancarlo Montanaro</p>

</footer>


</body>
</html>
